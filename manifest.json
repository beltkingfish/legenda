{
  "manifestVersion": 5,
  "id": "com.legenda.captions",
  "name": "Legenda",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "legenda.panel",
      "label": {
        "default": "Legenda"
      },
      "minimumSize": { "width": 300, "height": 400 },
      "maximumSize": { "width": 2000, "height": 2000 },
      "preferredDockedSize": { "width": 340, "height": 600 },
      "preferredFloatingSize": { "width": 340, "height": 600 }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request"
  }
}