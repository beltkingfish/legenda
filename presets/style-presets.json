  "defaults": {
    "animation": "fade",
    "timing": { "minSec": 1.33, "maxSec": 7.0, "transitionMs": 150, "gapMs": 100 },
    "wrapping": { "maxLinesVisible": 2, "targetLineChars": 32 }
  }
