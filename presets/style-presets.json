        "fontFamily": "Montserrat",
        "fontWeight": "Bold",
        "fontSize": 48,
        "lineHeight": 1.15,
        "letterSpacing": 0,
        "alignment": "center"
      },
      "textColor": "#FFFFFF",
      "background": {
        "enabled": true,
        "color": "#000000",
        "opacity": 0.6,
        "cornerRadius": 8,
        "paddingX": 24,
        "paddingY": 12
      },
      "outline": { "enabled": false, "width": 0, "color": "#000000" },
      "dropShadow": { "enabled": false, "color": "#000000", "opacity": 0.5, "blur": 6, "distance": 4 }
    },
    {
      "id": "bold",
      "name": "Bold",
      "description": "High-contrast, energetic. Promo and fast-paced content.",
      "typography": {
        "fontFamily": "Montserrat",
        "fontWeight": "ExtraBold",
        "fontSize": 60,
        "lineHeight": 1.1,
        "letterSpacing": 0.5,
        "alignment": "center"
      },
      "textColor": "#FFE94A",
      "background": {
        "enabled": true,
        "color": "#101010",
        "opacity": 0.85,
        "cornerRadius": 6,
        "paddingX": 20,
        "paddingY": 10
      },
      "outline": { "enabled": false, "width": 0, "color": "#000000" },
      "dropShadow": { "enabled": true, "color": "#000000", "opacity": 0.6, "blur": 8, "distance": 3 }
