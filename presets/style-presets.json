{
  "schemaVersion": "1.0.0",
  "note": "StyleDef shape is shared by presets, custom styles, and exported style files. Values are starting points; the plugin maps these 1:1 to exposed MOGRT parameters. Colors are hex; sizes are in the MOGRT's design units unless noted.",
  "presets": [
