    {
      "id": "minimal",
      "name": "Minimal",
      "description": "Text only, maximum transparency. Cinematic and visual-heavy.",
      "typography": {
        "fontFamily": "Montserrat",
        "fontWeight": "SemiBold",
        "fontSize": 44,
        "lineHeight": 1.2,
        "letterSpacing": 0,
        "alignment": "center"
      },
      "textColor": "#FFFFFF",
      "background": { "enabled": false, "color": "#000000", "opacity": 0.0, "cornerRadius": 0, "paddingX": 0, "paddingY": 0 },
      "outline": { "enabled": true, "width": 2, "color": "#000000" },
