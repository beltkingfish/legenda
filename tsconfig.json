{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    // UXP's DOM is a subset of the web DOM; @adobe/cc-ext-uxp-types provides it.
    // Per that package's README: exclude the standard "DOM" lib and add the
    // package directory as a typeRoot; "uxp" is the types package inside it.
    "lib": ["ES2022"],
    "typeRoots": [
      "node_modules/@types",
      "node_modules/@adobe/cc-ext-uxp-types"
    ],
    "types": ["uxp"],
    // tsc typechecks only; esbuild bundles src/main.ts → dist/main.js as an
    // IIFE (UXP <script> tags provide no CommonJS wrapper), with the host
    // modules ("premierepro", "uxp") left as runtime require() calls.
    "noEmit": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
